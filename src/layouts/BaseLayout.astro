---
import '../styles/global.css';

interface Props {
  title?: string;
}

const { title = 'Axiom AI Automation Agency' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Axiom builds bespoke AI automation systems for growth-focused teams." />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />
    <footer class="mt-auto border-t border-white/10 bg-[#090c0bb0] backdrop-blur-md">
      <div class="mx-auto max-w-[1180px] px-5 py-6 text-center max-[540px]:px-3.5 max-[540px]:py-4">
        <p class="m-0 text-[0.9rem] text-[#b9c2bc]">
          © 2026 Axiom AI Group. All Rights Reserved.
        </p>
      </div>
    </footer>
  </body>
</html>
